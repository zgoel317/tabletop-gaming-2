# Supabase project URL and anon key (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — SERVER ONLY, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Optional: used by Supabase CLI for local development
# SUPABASE_DB_PASSWORD=<your-local-db-password>
