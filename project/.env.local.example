# ============================================================
# Supabase
# ============================================================
# Found in your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — NEVER expose this to the browser.
# Used for server-side admin operations (e.g. bypassing RLS in migrations).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# Google Maps
# ============================================================
# Required for location-based player discovery features.
# Restrict the key to your domain in the Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================================
# BoardGameGeek API
# ============================================================
# Public XML API — no key required, but the base URL is configured here
# so it can be changed without touching code.
BOARDGAMEGEEK_API_BASE_URL=https://boardgamegeek.com/xmlapi2

# ============================================================
# AWS S3 (profile pictures and game images)
# ============================================================
AWS_S3_BUCKET_NAME=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
