# ============================================================
# Environment Variables — Tabletop Gaming Networking App
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Supabase (required)
# Find these in your Supabase project Settings > API
# ------------------------------------------------------------

# Public URL for your Supabase project (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — used by browser and server clients with RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — bypasses RLS, ONLY use in secure server contexts
# Never expose this to the browser or commit it to source control
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------

# The canonical URL of the app (used for OAuth redirects, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------------------------------
# BoardGameGeek API (optional)
# No API key required — BGG uses a public XML API
# ------------------------------------------------------------

BGG_API_BASE_URL=https://boardgamegeek.com/xmlapi2

# ------------------------------------------------------------
# Google Maps (optional — for location-based player search)
# https://console.cloud.google.com/apis/credentials
# ------------------------------------------------------------

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# ------------------------------------------------------------
# AWS S3 (optional — for avatar and image uploads)
# ------------------------------------------------------------

AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
